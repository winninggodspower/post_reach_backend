# Django
SECRET_KEY=replace-with-your-django-secret-key
DEBUG=False

# Database
# DATABASE_URL=postgres://user:password@host:5432/postreach

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Facebook OAuth
FACEBOOK_APP_ID=replace-with-facebook-client-id
FACEBOOK_APP_SECRET=replace-with-facebook-client-secret

# Instagram OAuth
INSTAGRAM_APP_ID=replace-with-instagram-app-id
INSTAGRAM_APP_SECRET=replace-with-instagram-app-secret

# TikTok OAuth
TIKTOK_CLIENT_KEY=replace-with-tiktok-client-key
TIKTOK_CLIENT_SECRET=replace-with-tiktok-client-secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=replace-with-linkedin-client-id
LINKEDIN_CLIENT_SECRET=replace-with-linkedin-client-secret

# Fernet encryption
# Must be a valid Fernet key, for example from:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=replace-with-fernet-secret-key

# OAuth Redirect base URL (used in production only; dev defaults to http://localhost:5173)
REDIRECT_BASE_URL=https://app.postreach.com

CLOUDFLARE_R2_ACCESS_KEY=replace-with-r2-access-key
CLOUDFLARE_R2_SECRET=replace-with-r2-secret
CLOUDFLARE_R2_BUCKET=postreach
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id

# Email (ZeptoMail)
# EMAIL_HOST=smtp.zeptomail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@postreach.app

# Celery / Redis
# In production, set these to your Redis instance (e.g. Redis Cloud, Heroku Redis, etc.)
# REDIS_URL=redis://:password@host:6379/0
